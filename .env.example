# MB MOTORS — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ─────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────
PORT=5000

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/mb_motors

# ─────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────
JWT_SECRET=your_long_random_secret_here_min_32_chars

# ─────────────────────────────────────────
# CORS & Frontend URL
# ─────────────────────────────────────────
# Local access:
#   FRONTEND_URL=http://localhost:5000
# Network access (replace with your machine IP):
#   FRONTEND_URL=http://192.168.x.x:5000
FRONTEND_URL=http://localhost:5000

# ─────────────────────────────────────────
# Optional: Deployment Platforms
# ─────────────────────────────────────────
# MONGODB_ATLAS_URI=your_mongodb_atlas_connection_string
# GOOGLE_OAUTH_ID=your_google_oauth_client_id
# GOOGLE_OAUTH_SECRET=your_google_oauth_client_secret
